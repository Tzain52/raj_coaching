# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR-SUPABASE-HOST].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR-SUPABASE-HOST].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Admin email list (comma separated, optional)
ADMIN_EMAILS="admin@example.com"
